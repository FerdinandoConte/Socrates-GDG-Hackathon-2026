          "id": "pq-01",
          "parentID": "peer-book-001",
          "type": "questions",
          "text": "What is the purpose of tiered isolation in agent design?",
          "answer": "To separate agents by trust level so that a compromised tier cannot access systems beyond its privilege boundary.",
          "pageNo": 6,
          "Card": { "due": "2026-05-20T10:00:00.000Z", "stability": 12.0, "difficulty": 3.5, "elapsed_days": 0, "scheduled_days": 12, "reps": 6, "lapses": 0, "state": 2, "last_review": "2026-05-08T10:00:00.000Z" },
