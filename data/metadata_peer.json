          "id": "pq-02",
          "parentID": "peer-book-001",
          "type": "questions",
          "text": "Which tier in the architecture is allowed MCP write access and why?",
          "answer": "Only the Orchestrator tier has MCP write access because it operates with verified identity and is never exposed to untrusted content.",
          "pageNo": 7,
