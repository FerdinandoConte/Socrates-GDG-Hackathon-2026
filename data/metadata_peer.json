        {
          "id": "pq-04",
          "parentID": "peer-book-001",
          "type": "questions",
          "text": "Why is the Reader MCP denied write access?",
          "answer": "Because the Reader processes untrusted external content (PDFs, web pages). Giving it write access would allow prompt-injected instructions to modify data.",
